# Semantik Galaksi — .gitattributes
# ═══════════════════════════════════════════════════════════════

# Satır sonu normalizasyonu
* text=auto

# Python
*.py text diff=python

# JavaScript / HTML / CSS
*.js text
*.html text diff=html
*.css text

# JSON
*.json text

# Markdown
*.md text

# Batch / Shell
*.bat text eol=crlf
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
