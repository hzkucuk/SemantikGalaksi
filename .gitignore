# ─── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Virtual Environment
DataEngine/env/
venv/
.venv/
env/

# ─── PyInstaller ──────────────────────────────────────────────
build/
dist/
*.spec.bak

# ─── Güvenlik & Gizli Dosyalar ───────────────────────────────
.env
DataEngine/.env
*.env
.api_keys
DataEngine/webview_data/

# ─── Visual Studio ────────────────────────────────────────────
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# ─── IDE & Editör ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── İşletim Sistemi ─────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ─── Log & Geçici Dosyalar ───────────────────────────────────
*.log
*.tmp
[Ll]og/
[Ll]ogs/
